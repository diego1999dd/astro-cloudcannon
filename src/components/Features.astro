---
interface FeatureItem {
  title: string;
  description: string;
}

interface Props {
  items: FeatureItem[];
}

const { items } = Astro.props;
---

<section class="py-16">
  <div class="mb-8">
    <h2 class="text-3xl font-bold text-sky-400">Features</h2>
    <p class="mt-2 text-slate-300">Alguns pontos do projeto.</p>
  </div>

  <div class="grid gap-6 md:grid-cols-3">
    {items.map((item) => (
      <article class="rounded-2xl border border-slate-700 bg-slate-800 p-6">
        <h3 class="mb-3 text-xl font-semibold text-white">{item.title}</h3>
        <p class="text-slate-300">{item.description}</p>
      </article>
    ))}
  </div>
</section>