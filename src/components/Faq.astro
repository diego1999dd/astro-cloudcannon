---
interface Item {
  question: string;
  answer: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<section class="py-16">
  <h2 class="text-3xl font-bold mb-8 text-sky-400">FAQ</h2>

  <div class="space-y-6">
    {items.map((item) => (
      <div class="border border-slate-700 rounded-xl p-4">
        <h3 class="font-semibold text-white">{item.question}</h3>
        <p class="text-slate-300 mt-2">{item.answer}</p>
      </div>
    ))}
  </div>
</section>